{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "GH_ATTACH_BUILD_VERSION=${nextRelease.version} npm run build"
      }
    ],
    "@semantic-release/npm",
    [
      "@semantic-release/github",
      {
        "assets": [
          { "path": "bin/gh-attach-linux-amd64", "label": "Linux x64 binary" },
          { "path": "bin/gh-attach-darwin-amd64", "label": "macOS x64 binary" },
          {
            "path": "bin/gh-attach-darwin-arm64",
            "label": "macOS arm64 binary"
          },
          {
            "path": "bin/gh-attach-windows-amd64.exe",
            "label": "Windows x64 binary"
          },
          { "path": "gh-extension", "label": "gh extension manifest" }
        ]
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md", "package.json", "package-lock.json"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
